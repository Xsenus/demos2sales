root = true

[*.{py,md,txt,sh,yml,yaml,service,sql,json,toml,ini,cfg,html,css,js}]
charset = utf-8
end_of_line = lf
insert_final_newline = true
indent_style = space
indent_size = 4

[.gitignore]
charset = utf-8
end_of_line = lf
insert_final_newline = true

[.gitattributes]
charset = utf-8
end_of_line = lf
insert_final_newline = true

[.editorconfig]
charset = utf-8
end_of_line = lf
insert_final_newline = true

[requirements.txt]
charset = utf-8
end_of_line = lf
insert_final_newline = true

[*.example]
charset = utf-8
end_of_line = lf
insert_final_newline = true

[*.md]
trim_trailing_whitespace = false
